            {
              "rmxp_raw": true,
              "code": 102,
              "indent": 1,
              "parameters": [
                [
                  "Battle Factory rules",
                  "Play recorded battle",
                  "Cancel"
                ],
                3
              ]
            },
            {
              "rmxp_raw": true,
              "code": 402,
              "indent": 1,
              "parameters": [
                0,
                "Battle Factory rules"
              ]
            },
            {
              "rmxp_raw": true,
              "code": 118,
              "indent": 2,
              "parameters": [
                "Choices"
              ]
            },
            {
              "rmxp_raw": true,
              "code": 101,
              "indent": 2,
              "parameters": [
                "Which heading do you want to read?"
              ]
            },
            {
              "rmxp_raw": true,
              "code": 102,
              "indent": 2,
              "parameters": [
                [
                  "Basic Rules",
                  "Swapping",
                  "Exit"
                ],
                5
              ]
            },
            {
              "rmxp_raw": true,
              "code": 402,
              "indent": 2,
              "parameters": [
                0,
                "Basic Rules"
              ]
            },
            {
              "rmxp_raw": true,
              "code": 101,
              "indent": 3,
              "parameters": [
                "In the Battle Factory, you fight using Pok\u00e9mon "
              ]
            },
            {
              "rmxp_raw": true,
              "code": 401,
              "indent": 3,
              "parameters": [
                "provided for you. You must use three Pok\u00e9mon out of "
              ]
            },
            {
              "rmxp_raw": true,
              "code": 401,
              "indent": 3,
              "parameters": [
                "a choice of six."
              ]
            },
            {
              "rmxp_raw": true,
              "code": 101,
              "indent": 3,
              "parameters": [
                "Pok\u00e9mon in later rounds will be stronger than in "
              ]
            },
            {
              "rmxp_raw": true,
              "code": 401,
              "indent": 3,
              "parameters": [
                "earlier rounds, both yours and your opponents'."
              ]
            },
            {
              "rmxp_raw": true,
              "code": 119,
              "indent": 3,
              "parameters": [
                "Choices"
              ]
            },
            {
              "rmxp_raw": true,
              "code": 0,
              "indent": 3,
              "parameters": []
            },
            {
              "rmxp_raw": true,
              "code": 402,
              "indent": 2,
              "parameters": [
                1,
                "Swapping"
              ]
            },
            {
              "rmxp_raw": true,
              "code": 101,
              "indent": 3,
              "parameters": [
                "When you defeat a Trainer, you may swap one of "
              ]
            },
            {
              "rmxp_raw": true,
              "code": 401,
              "indent": 3,
              "parameters": [
                "your Pok\u00e9mon for one of theirs."
              ]
            },
            {
              "rmxp_raw": true,
              "code": 101,
              "indent": 3,
              "parameters": [
                "You can't check the details of the Trainer's Pok\u00e9mon "
              ]
            },
            {
              "rmxp_raw": true,
              "code": 401,
              "indent": 3,
              "parameters": [
                "before you choose one to gain in a swap. You will "
              ]
            },
            {
              "rmxp_raw": true,
              "code": 401,
              "indent": 3,
              "parameters": [
                "have to remember what it was like from the battle."
              ]
            },
            {
              "rmxp_raw": true,
              "code": 101,
              "indent": 3,
              "parameters": [
                "Your team will remain in the same order even after a "
              ]
            },
            {
              "rmxp_raw": true,
              "code": 401,
              "indent": 3,
              "parameters": [
                "swap. For example, if you swap away your second "
              ]
            },
            {
              "rmxp_raw": true,
              "code": 401,
              "indent": 3,
              "parameters": [
                "Pok\u00e9mon, the new Pok\u00e9mon will now be second."
              ]
            },
            {
              "rmxp_raw": true,
              "code": 119,
              "indent": 3,
