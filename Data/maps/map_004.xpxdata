            "opacity": 255,
            "blend_type": 0
          },
          "commands": [
            {
              "rmxp_raw": true,
              "code": 108,
              "indent": 0,
              "parameters": [
                "This event is size 3x1. It is 3 tiles wide and 1 tile tall. "
              ]
            },
            {
              "rmxp_raw": true,
              "code": 408,
              "indent": 0,
              "parameters": [
                "An event's size can be set by adding \"size(x,y)\" in the "
              ]
            },
            {
              "rmxp_raw": true,
              "code": 408,
              "indent": 0,
              "parameters": [
                "event's name, where x and y are numbers."
              ]
            },
            {
              "rmxp_raw": true,
              "code": 108,
              "indent": 0,
              "parameters": [
                "The event's placed position determines the bottom "
              ]
            },
            {
              "rmxp_raw": true,
              "code": 408,
              "indent": 0,
              "parameters": [
                "left tile occupied by the event in-game."
              ]
            },
            {
              "rmxp_raw": true,
              "code": 108,
              "indent": 0,
              "parameters": [
                "There are a lot of reasons to change an event's size. "
              ]
            },
            {
              "rmxp_raw": true,
              "code": 408,
              "indent": 0,
              "parameters": [
                "Here, it is covering the whole distance between the "
              ]
            },
            {
              "rmxp_raw": true,
              "code": 408,
              "indent": 0,
              "parameters": [
                "bookshelves with just one event, rather than needing "
              ]
            },
            {
              "rmxp_raw": true,
              "code": 408,
              "indent": 0,
              "parameters": [
                "three events that do the same thing."
              ]
            },
            {
              "rmxp_raw": true,
              "code": 0,
              "indent": 0,
              "parameters": []
            }
          ],
          "move_route": {
            "repeat": true,
            "skippable": false,
