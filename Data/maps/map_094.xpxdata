            },
            {
              "rmxp_raw": true,
              "code": 106,
              "indent": 2,
              "parameters": [
                20
              ]
            },
            {
              "rmxp_raw": true,
              "code": 101,
              "indent": 2,
              "parameters": [
                "\\bOh, hello!\\nYou filled in the questionnaire?"
              ]
            },
            {
              "rmxp_raw": true,
              "code": 101,
              "indent": 2,
              "parameters": [
                "\\bThat means you must know about the Mystery Gift."
              ]
            },
            {
              "rmxp_raw": true,
              "code": 101,
              "indent": 2,
              "parameters": [
                "\\bFrom now on, you should be receiving Mystery "
              ]
            },
            {
              "rmxp_raw": true,
              "code": 401,
              "indent": 2,
              "parameters": [
                "Gifts!"
              ]
            },
