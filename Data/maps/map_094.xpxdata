              "rmxp_raw": true,
              "code": 355,
              "indent": 2,
              "parameters": [
                "$player.mystery_gift_unlocked = true"
              ]
            },
            {
              "rmxp_raw": true,
              "code": 101,
              "indent": 2,
              "parameters": [
                "\\w[signskin]Once you save your game, you can "
              ]
            },
            {
              "rmxp_raw": true,
