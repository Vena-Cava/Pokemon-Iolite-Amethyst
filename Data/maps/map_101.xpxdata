                "DayCare.count == 0"
              ]
            },
            {
              "rmxp_raw": true,
              "code": 101,
              "indent": 1,
              "parameters": [
                "\\rI'm the Day-Care Lady. We can raise Pok\u00e9mon for "
              ]
            },
            {
              "rmxp_raw": true,
              "code": 401,
              "indent": 1,
              "parameters": [
                "you."
              ]
            },
            {
              "rmxp_raw": true,
              "code": 101,
              "indent": 1,
              "parameters": [
                "\\rWould you like us to raise your Pok\u00e9mon?"
              ]
            },
            {
              "rmxp_raw": true,
              "code": 102,
              "indent": 1,
              "parameters": [
                [
                  "Yes",
                  "No"
                ],
                2
              ]
            },
            {
              "rmxp_raw": true,
              "code": 402,
              "indent": 1,
              "parameters": [
                0,
                "Yes"
              ]
            },
            {
              "rmxp_raw": true,
              "code": 111,
              "indent": 2,
              "parameters": [
                12,
                "$player.pokemon_count <= 1"
              ]
            },
            {
              "rmxp_raw": true,
              "code": 101,
              "indent": 3,
              "parameters": [
                "\\rOh? But you only have one Pok\u00e9mon with you."
