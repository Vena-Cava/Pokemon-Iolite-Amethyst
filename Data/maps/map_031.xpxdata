    "22,13": {
      "id": 15,
      "name": "Rival controller size(2,1)",
      "x": 22,
      "y": 13,
      "pages": [
        {
          "trigger": "Player Touch",
          "condition_switch": null,
          "condition_switch_state": true,
          "condition_switch2": null,
          "condition_switch2_state": true,
          "condition_self_switch": null,
          "condition_variable_id": null,
          "condition_variable_value": 0,
          "condition_variable_operator": 1,
          "graphic_name": "",
          "graphic": {
            "tile_id": 0,
            "character_name": "",
            "character_hue": 0,
            "direction": 2,
            "pattern": 0,
            "opacity": 255,
            "blend_type": 0
          },
          "commands": [
            {
              "rmxp_raw": true,
              "code": 108,
              "indent": 0,
              "parameters": [
                "This event is size 2x1. It is 2 tiles wide and 1 tile tall. "
              ]
            },
            {
              "rmxp_raw": true,
              "code": 408,
              "indent": 0,
              "parameters": [
                "An event's size can be set by adding \"size(x,y)\" in the "
              ]
            },
            {
              "rmxp_raw": true,
              "code": 408,
              "indent": 0,
              "parameters": [
                "event's name, where x and y are numbers."
              ]
            },
            {
              "rmxp_raw": true,
              "code": 108,
              "indent": 0,
              "parameters": [
                "The event's placed position determines the bottom "
              ]
            },
            {
              "rmxp_raw": true,
              "code": 408,
              "indent": 0,
              "parameters": [
                "left tile occupied by the event in-game."
              ]
            },
            {
              "rmxp_raw": true,
              "code": 108,
              "indent": 0,
              "parameters": [
                "There are a lot of reasons to change an event's size. "
              ]
            },
            {
              "rmxp_raw": true,
              "code": 408,
              "indent": 0,
              "parameters": [
                "Here, it is covering the whole path with just one "
              ]
            },
            {
              "rmxp_raw": true,
              "code": 408,
              "indent": 0,
              "parameters": [
                "event, rather than needing two events that do the "
              ]
            },
            {
              "rmxp_raw": true,
              "code": 408,
              "indent": 0,
              "parameters": [
                "same thing."
              ]
            },
            {
              "rmxp_raw": true,
              "code": 355,
              "indent": 0,
              "parameters": [
                "pbTrainerIntro(:RIVAL1)"
              ]
            },
            {
              "rmxp_raw": true,
              "code": 108,
              "indent": 0,
              "parameters": [
