            "blend_type": 0
          },
          "commands": [
            {
              "rmxp_raw": true,
              "code": 108,
              "indent": 0,
              "parameters": [
                "If the player blacked out while May was following "
              ]
            },
            {
              "rmxp_raw": true,
              "code": 408,
              "indent": 0,
              "parameters": [
                "them, May should return to being this event. This "
              ]
            },
            {
              "rmxp_raw": true,
              "code": 408,
              "indent": 0,
              "parameters": [
                "page of this event runs automatically whenever this "
              ]
            },
            {
              "rmxp_raw": true,
              "code": 408,
              "indent": 0,
              "parameters": [
                "map is loaded, and at no other time."
              ]
            },
            {
              "rmxp_raw": true,
              "code": 108,
              "indent": 0,
              "parameters": [
                "May should only reappear here if she is not currently "
              ]
            },
            {
              "rmxp_raw": true,
              "code": 408,
              "indent": 0,
              "parameters": [
                "following the player. This first Conditional Branch "
              ]
            },
            {
              "rmxp_raw": true,
              "code": 408,
              "indent": 0,
              "parameters": [
                "checks for that."
              ]
            },
            {
              "rmxp_raw": true,
              "code": 111,
              "indent": 0,
              "parameters": [
                12,
                "!$game_player.has_follower?"
              ]
            },
            {
              "rmxp_raw": true,
              "code": 108,
              "indent": 1,
              "parameters": [
                "Event 44 is another May event, and is the only way "
              ]
            },
            {
              "rmxp_raw": true,
              "code": 408,
              "indent": 1,
              "parameters": [
                "to make May appear somewhere else on her own (i.e. "
              ]
            },
            {
              "rmxp_raw": true,
              "code": 408,
              "indent": 1,
              "parameters": [
                "not being a follower)."
              ]
            },
            {
              "rmxp_raw": true,
              "code": 108,
              "indent": 1,
              "parameters": [
                "While event 44 is May, its Self Switch A will be ON. "
              ]
            },
            {
              "rmxp_raw": true,
              "code": 408,
              "indent": 1,
              "parameters": [
                "Therefore, if its Self Switch A is OFF, it is not May, "
              ]
            },
            {
              "rmxp_raw": true,
              "code": 408,
              "indent": 1,
              "parameters": [
                "and this event should be May (because she is not a "
              ]
            },
            {
              "rmxp_raw": true,
              "code": 408,
              "indent": 1,
              "parameters": [
                "follower). This second Conditional Branch checks if "
              ]
            },
            {
              "rmxp_raw": true,
              "code": 408,
              "indent": 1,
              "parameters": [
                "event 44's Self Switch A is off."
              ]
            },
            {
              "rmxp_raw": true,
              "code": 111,
              "indent": 1,
              "parameters": [
                12,
                "get_event(44).isOff?(\"A\")"
              ]
            },
            {
              "rmxp_raw": true,
              "code": 108,
              "indent": 2,
              "parameters": [
                "Since event 44 is not May, this event should be May. "
              ]
            },
            {
              "rmxp_raw": true,
              "code": 408,
              "indent": 2,
              "parameters": [
                "This event's Self Switch A should be turned OFF to "
              ]
            },
            {
              "rmxp_raw": true,
              "code": 408,
              "indent": 2,
              "parameters": [
                "make its page 1 active (which shows May)."
              ]
            },
            {
              "rmxp_raw": true,
              "code": 123,
              "indent": 2,
              "parameters": [
                "A",
                1
              ]
            },
            {
              "rmxp_raw": true,
              "code": 0,
              "indent": 2,
              "parameters": []
            },
            {
              "rmxp_raw": true,
              "code": 412,
              "indent": 1,
              "parameters": []
            },
            {
              "rmxp_raw": true,
              "code": 0,
              "indent": 1,
              "parameters": []
            },
            {
              "rmxp_raw": true,
