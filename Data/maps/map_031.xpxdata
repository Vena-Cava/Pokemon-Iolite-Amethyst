        {
          "trigger": "Action Button",
          "condition_switch": null,
          "condition_switch_state": true,
          "condition_switch2": null,
          "condition_switch2_state": true,
          "condition_self_switch": "A",
          "condition_variable_id": null,
          "condition_variable_value": 0,
          "condition_variable_operator": 1,
          "graphic_name": "trainer_POKEMONTRAINER_May",
          "graphic": {
            "tile_id": 0,
            "character_name": "trainer_POKEMONTRAINER_May",
            "character_hue": 0,
            "direction": 2,
            "pattern": 0,
            "opacity": 255,
            "blend_type": 0
          },
          "commands": [
            {
              "rmxp_raw": true,
              "code": 108,
              "indent": 0,
              "parameters": [
                "Normally, once you have escorted an NPC trainer to "
              ]
            },
            {
              "rmxp_raw": true,
              "code": 408,
              "indent": 0,
              "parameters": [
                "the end of a dungeon, they will just remain there "
              ]
            },
            {
              "rmxp_raw": true,
              "code": 408,
              "indent": 0,
              "parameters": [
                "and cannot be made to follow the player again. "
              ]
            },
            {
              "rmxp_raw": true,
              "code": 408,
              "indent": 0,
              "parameters": [
                "However, for the sake of example, this page does let "
              ]
            },
            {
              "rmxp_raw": true,
              "code": 408,
              "indent": 0,
              "parameters": [
                "May follow the player again."
              ]
            },
            {
              "rmxp_raw": true,
              "code": 101,
              "indent": 0,
              "parameters": [
                "\\rDo you want to team up with me again?"
              ]
            },
            {
              "rmxp_raw": true,
              "code": 102,
              "indent": 0,
              "parameters": [
                [
                  "Yes",
                  "No"
                ],
                2
              ]
            },
            {
              "rmxp_raw": true,
              "code": 402,
              "indent": 0,
              "parameters": [
                0,
                "Yes"
              ]
            },
            {
              "rmxp_raw": true,
              "code": 108,
              "indent": 1,
              "parameters": [
                "Makes this event follow the player. The first "
              ]
            },
            {
              "rmxp_raw": true,
              "code": 408,
              "indent": 1,
              "parameters": [
                "parameter means \"this event\", the second is a name "
              ]
            },
            {
              "rmxp_raw": true,
              "code": 408,
              "indent": 1,
              "parameters": [
                "that identifies this follower, and the third is the "
              ]
            },
            {
              "rmxp_raw": true,
              "code": 408,
              "indent": 1,
              "parameters": [
                "Common Event number run when this follower is "
              ]
            },
            {
              "rmxp_raw": true,
              "code": 408,
              "indent": 1,
              "parameters": [
                "interacted with."
              ]
            },
            {
              "rmxp_raw": true,
              "code": 355,
              "indent": 1,
              "parameters": [
                "Followers.add(@event_id, \"May\", 2)"
              ]
            },
            {
              "rmxp_raw": true,
              "code": 108,
              "indent": 1,
              "parameters": [
                "Followers.add does not make this event disappear. It "
              ]
            },
            {
              "rmxp_raw": true,
              "code": 408,
              "indent": 1,
              "parameters": [
                "should be hidden by using a Self Switch to make it use "
              ]
            },
            {
              "rmxp_raw": true,
              "code": 408,
              "indent": 1,
              "parameters": [
                "a blank event page instead."
              ]
            },
            {
              "rmxp_raw": true,
              "code": 123,
              "indent": 1,
              "parameters": [
                "A",
                1
              ]
            },
            {
              "rmxp_raw": true,
              "code": 108,
              "indent": 1,
              "parameters": [
                "Creates a partner trainer to battle alongside the "
              ]
            },
            {
              "rmxp_raw": true,
              "code": 408,
              "indent": 1,
              "parameters": [
                "player. The parameters are the trainer type and "
              ]
            },
            {
              "rmxp_raw": true,
              "code": 408,
              "indent": 1,
              "parameters": [
                "name of the partner. The partner trainer is defined "
              ]
            },
            {
              "rmxp_raw": true,
              "code": 408,
              "indent": 1,
              "parameters": [
                "in trainers.txt just like any other trainer."
              ]
            },
            {
              "rmxp_raw": true,
              "code": 355,
              "indent": 1,
              "parameters": [
                "pbRegisterPartner("
              ]
            },
            {
              "rmxp_raw": true,
              "code": 655,
              "indent": 1,
              "parameters": [
                "  :POKEMONTRAINER_May,"
              ]
            },
            {
              "rmxp_raw": true,
              "code": 655,
              "indent": 1,
              "parameters": [
                "  \"May\""
              ]
            },
            {
              "rmxp_raw": true,
              "code": 655,
              "indent": 1,
              "parameters": [
                ")"
              ]
            },
            {
              "rmxp_raw": true,
              "code": 108,
              "indent": 1,
              "parameters": [
                "Note that the above two features are entirely "
              ]
            },
            {
              "rmxp_raw": true,
              "code": 408,
              "indent": 1,
              "parameters": [
                "unrelated. You can have a follower which isn't also a "
              ]
            },
            {
              "rmxp_raw": true,
              "code": 408,
              "indent": 1,
              "parameters": [
                "partner trainer (e.g. escort mission), or a partner "
              ]
            },
            {
              "rmxp_raw": true,
              "code": 408,
              "indent": 1,
              "parameters": [
                "trainer who doesn't visibly follow you around."
              ]
            },
            {
              "rmxp_raw": true,
              "code": 101,
              "indent": 1,
              "parameters": [
                "\\PN teamed up with May!\\me[Item get]\\wtnp[40]"
              ]
            },
            {
              "rmxp_raw": true,
              "code": 108,
              "indent": 1,
              "parameters": [
                "This Set Move Route command is to ensure that May "
              ]
            },
            {
              "rmxp_raw": true,
              "code": 408,
              "indent": 1,
              "parameters": [
                "faces down once she stops following the player. "
              ]
            },
            {
              "rmxp_raw": true,
              "code": 408,
              "indent": 1,
              "parameters": [
                "Without this, she will be facing in whichever direction "
              ]
            },
            {
              "rmxp_raw": true,
              "code": 408,
              "indent": 1,
              "parameters": [
                "she was facing when the player talked to this event "
              ]
            },
            {
              "rmxp_raw": true,
              "code": 408,
              "indent": 1,
              "parameters": [
                "to add May as a follower."
              ]
            },
            {
              "rmxp_raw": true,
              "code": 209,
              "indent": 1,
              "parameters": [
                0,
                {
                  "repeat": false,
                  "skippable": false,
                  "list": [
                    {
                      "code": 16,
                      "parameters": []
                    },
                    {
                      "code": 0,
                      "parameters": []
                    }
                  ]
                }
              ]
            },
            {
              "rmxp_raw": true,
              "code": 509,
              "indent": 1,
              "parameters": [
                {
                  "code": 16,
                  "parameters": []
                }
              ]
            },
            {
              "rmxp_raw": true,
              "code": 0,
