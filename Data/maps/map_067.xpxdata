          "condition_variable_operator": 1,
          "graphic_name": "NPC 07",
          "graphic": {
            "tile_id": 0,
            "character_name": "NPC 07",
            "character_hue": 0,
            "direction": 4,
            "pattern": 0,
            "opacity": 255,
            "blend_type": 0
          },
          "commands": [
            {
              "rmxp_raw": true,
              "code": 108,
              "indent": 0,
              "parameters": [
                "This event can notice the player at a distance even "
              ]
            },
            {
              "rmxp_raw": true,
              "code": 408,
              "indent": 0,
              "parameters": [
                "though an impassable tile (the desk) is in the way. "
              ]
            },
            {
              "rmxp_raw": true,
              "code": 408,
              "indent": 0,
              "parameters": [
                "This is because this event's name contains the text "
              ]
            },
            {
              "rmxp_raw": true,
              "code": 408,
              "indent": 0,
              "parameters": [
                "\"Counter(X)\", where \"X\" is the number of tiles in front "
              ]
            },
            {
              "rmxp_raw": true,
              "code": 408,
              "indent": 0,
              "parameters": [
                "of itself that it can see."
              ]
            },
            {
              "rmxp_raw": true,
              "code": 101,
              "indent": 0,
              "parameters": [
                "\\bWelcome to the Safari Zone!"
              ]
            },
            {
              "rmxp_raw": true,
              "code": 209,
              "indent": 0,
              "parameters": [
                -1,
                {
                  "repeat": false,
                  "skippable": false,
                  "list": [
