    "14,12": {
      "id": 8,
      "name": "Mew",
      "x": 14,
      "y": 12,
      "pages": [
        {
          "trigger": "Action Button",
          "condition_switch": null,
          "condition_switch_state": true,
          "condition_switch2": null,
          "condition_switch2_state": true,
          "condition_self_switch": null,
          "condition_variable_id": null,
          "condition_variable_value": 0,
          "condition_variable_operator": 1,
          "graphic_name": "Pokemon 09",
          "graphic": {
            "tile_id": 0,
            "character_name": "Pokemon 09",
            "character_hue": 180,
            "direction": 2,
            "pattern": 1,
            "opacity": 255,
            "blend_type": 0
          },
          "commands": [
            {
              "rmxp_raw": true,
              "code": 108,
              "indent": 0,
              "parameters": [
                "Mew reappears after each time the Elite Four are "
              ]
            },
            {
              "rmxp_raw": true,
              "code": 408,
              "indent": 0,
              "parameters": [
                "defeated. The command that does this is in the event "
              ]
            },
            {
              "rmxp_raw": true,
              "code": 408,
              "indent": 0,
              "parameters": [
                "in the Hall of Fame map."
              ]
            },
            {
              "rmxp_raw": true,
              "code": 408,
              "indent": 0,
              "parameters": [
                "Mew will not reappear if it has been caught, though. "
              ]
            },
            {
              "rmxp_raw": true,
              "code": 408,
              "indent": 0,
              "parameters": [
                "This is why this event sets Self Switch B if it is caught, "
              ]
            },
            {
              "rmxp_raw": true,
              "code": 408,
              "indent": 0,
              "parameters": [
                "to avoid it reappearing."
              ]
            },
            {
              "rmxp_raw": true,
              "code": 355,
              "indent": 0,
              "parameters": [
                "Pokemon.play_cry(:MEW)"
              ]
            },
            {
              "rmxp_raw": true,
              "code": 106,
              "indent": 0,
              "parameters": [
                15
              ]
            },
            {
              "rmxp_raw": true,
              "code": 121,
              "indent": 0,
              "parameters": [
                31,
                31,
                0
              ]
            },
            {
              "rmxp_raw": true,
              "code": 121,
              "indent": 0,
              "parameters": [
                32,
                32,
                0
              ]
            },
            {
              "rmxp_raw": true,
              "code": 355,
              "indent": 0,
              "parameters": [
                "WildBattle.start(:MEW, 30)"
              ]
            },
            {
              "rmxp_raw": true,
              "code": 121,
              "indent": 0,
              "parameters": [
                31,
                31,
                1
              ]
            },
            {
              "rmxp_raw": true,
              "code": 121,
              "indent": 0,
              "parameters": [
                32,
                32,
                1
              ]
            },
            {
              "rmxp_raw": true,
              "code": 108,
              "indent": 0,
              "parameters": [
                "A battle's outcome is stored in Game Variable 1 by "
              ]
            },
            {
              "rmxp_raw": true,
              "code": 408,
              "indent": 0,
              "parameters": [
                "default. You can change this by putting the script "
              ]
            },
            {
              "rmxp_raw": true,
              "code": 408,
              "indent": 0,
              "parameters": [
                "\"setBattleRule(\"outcome\", 42)\" before the battle, "
              ]
            },
            {
              "rmxp_raw": true,
              "code": 408,
              "indent": 0,
              "parameters": [
                "where 42 is the Game Variable number you want."
              ]
            },
            {
              "rmxp_raw": true,
              "code": 111,
              "indent": 0,
              "parameters": [
                1,
                1,
                0,
                4,
                0
              ]
            },
            {
              "rmxp_raw": true,
              "code": 108,
              "indent": 1,
              "parameters": [
                "Caught."
              ]
            },
            {
              "rmxp_raw": true,
              "code": 123,
              "indent": 1,
              "parameters": [
                "B",
                0
              ]
            },
            {
              "rmxp_raw": true,
