              ]
            },
            {
              "rmxp_raw": true,
              "code": 655,
              "indent": 3,
              "parameters": [
                "best[0] = nil"
              ]
            },
            {
              "rmxp_raw": true,
              "code": 655,
              "indent": 3,
              "parameters": [
