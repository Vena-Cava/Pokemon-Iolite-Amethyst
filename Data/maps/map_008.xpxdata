              ]
            },
            {
              "rmxp_raw": true,
              "code": 101,
              "indent": 4,
              "parameters": [
                "\\bThis Pok\u00e9mon's potential is above average overall."
              ]
            },
            {
              "rmxp_raw": true,
              "code": 0,
              "indent": 4,
              "parameters": []
            },
            {
              "rmxp_raw": true,
              "code": 411,
              "indent": 3,
              "parameters": []
            },
            {
              "rmxp_raw": true,
              "code": 101,
              "indent": 4,
              "parameters": [
                "\\bThis Pok\u00e9mon's potential is decent overall."
              ]
            },
            {
              "rmxp_raw": true,
              "code": 0,
              "indent": 4,
              "parameters": []
            },
            {
              "rmxp_raw": true,
              "code": 412,
              "indent": 3,
              "parameters": []
            },
            {
              "rmxp_raw": true,
              "code": 0,
              "indent": 3,
              "parameters": []
            },
            {
              "rmxp_raw": true,
              "code": 412,
              "indent": 2,
              "parameters": []
            },
            {
              "rmxp_raw": true,
              "code": 0,
              "indent": 2,
              "parameters": []
            },
            {
              "rmxp_raw": true,
              "code": 412,
              "indent": 1,
              "parameters": []
            },
            {
              "rmxp_raw": true,
              "code": 101,
              "indent": 1,
              "parameters": [
                "\\bThat's my determination, and it's final."
              ]
            },
            {
              "rmxp_raw": true,
              "code": 108,
              "indent": 1,
              "parameters": [
                "Find out which stat(s) have the highest value, and "
              ]
            },
            {
              "rmxp_raw": true,
              "code": 408,
              "indent": 1,
              "parameters": [
                "show a message about each of them."
              ]
            },
            {
              "rmxp_raw": true,
              "code": 355,
              "indent": 1,
              "parameters": [
                "pkmn = pbGetPokemon(1)"
              ]
            },
            {
              "rmxp_raw": true,
              "code": 655,
              "indent": 1,
              "parameters": [
                "ivs  = pkmn.calcIV"
              ]
            },
            {
              "rmxp_raw": true,
              "code": 655,
              "indent": 1,
              "parameters": [
                "best = []"
              ]
            },
            {
              "rmxp_raw": true,
              "code": 655,
              "indent": 1,
              "parameters": [
                "val  = -1"
              ]
            },
            {
              "rmxp_raw": true,
              "code": 355,
              "indent": 1,
              "parameters": [
                "[:HP, :ATTACK, :DEFENSE,"
              ]
            },
            {
              "rmxp_raw": true,
              "code": 655,
              "indent": 1,
              "parameters": [
                " :SPECIAL_ATTACK, :SPECIAL_DEFENSE,"
              ]
            },
            {
              "rmxp_raw": true,
              "code": 655,
              "indent": 1,
              "parameters": [
                " :SPEED].each do |s|"
              ]
            },
            {
              "rmxp_raw": true,
              "code": 655,
              "indent": 1,
              "parameters": [
                "  if ivs[s] > val"
              ]
            },
            {
              "rmxp_raw": true,
              "code": 655,
              "indent": 1,
              "parameters": [
                "    best = [s]"
              ]
            },
            {
              "rmxp_raw": true,
              "code": 655,
              "indent": 1,
              "parameters": [
                "    val  = ivs[s]"
              ]
            },
            {
              "rmxp_raw": true,
              "code": 655,
              "indent": 1,
              "parameters": [
                "  elsif ivs[s] == val"
              ]
            },
            {
              "rmxp_raw": true,
              "code": 655,
              "indent": 1,
              "parameters": [
                "    best.push(s)"
              ]
            },
            {
              "rmxp_raw": true,
              "code": 655,
              "indent": 1,
              "parameters": [
                "  end"
              ]
            },
            {
              "rmxp_raw": true,
              "code": 655,
              "indent": 1,
              "parameters": [
                "end"
              ]
            },
            {
              "rmxp_raw": true,
              "code": 355,
              "indent": 1,
              "parameters": [
                "pbSet(2, best)"
              ]
            },
            {
              "rmxp_raw": true,
              "code": 655,
              "indent": 1,
              "parameters": [
                "pbSet(3, val)"
              ]
            },
            {
              "rmxp_raw": true,
              "code": 655,
              "indent": 1,
              "parameters": [
                "data = GameData::Stat.get(best[0])"
              ]
            },
            {
              "rmxp_raw": true,
              "code": 655,
              "indent": 1,
              "parameters": [
                "pbSet(4, data.name)"
              ]
            },
            {
              "rmxp_raw": true,
              "code": 655,
              "indent": 1,
              "parameters": [
                "pbSet(5, best.length - 1)"
              ]
            },
            {
              "rmxp_raw": true,
              "code": 101,
              "indent": 1,
              "parameters": [
                "\\bIncidentally, I would say the best potential lies in its "
              ]
            },
            {
              "rmxp_raw": true,
              "code": 401,
              "indent": 1,
              "parameters": [
                "\\v[4] stat."
              ]
            },
            {
              "rmxp_raw": true,
              "code": 112,
              "indent": 1,
              "parameters": []
            },
