  "events": {
    "3,4": {
      "id": 5,
      "name": "Contest ribbon giver",
      "x": 3,
      "y": 4,
      "pages": [
        {
          "trigger": "Action Button",
          "condition_switch": null,
          "condition_switch_state": true,
          "condition_switch2": null,
          "condition_switch2_state": true,
          "condition_self_switch": null,
          "condition_variable_id": null,
          "condition_variable_value": 0,
          "condition_variable_operator": 1,
          "graphic_name": "trainer_LADY",
          "graphic": {
            "tile_id": 0,
            "character_name": "trainer_LADY",
            "character_hue": 0,
            "direction": 2,
            "pattern": 0,
            "opacity": 255,
            "blend_type": 0
          },
          "commands": [
            {
              "rmxp_raw": true,
              "code": 108,
              "indent": 0,
              "parameters": [
                "Gives or upgrades a contest ribbon for the lead "
              ]
            },
            {
              "rmxp_raw": true,
              "code": 408,
              "indent": 0,
              "parameters": [
                "Pok\u00e9mon."
              ]
            },
            {
              "rmxp_raw": true,
              "code": 408,
              "indent": 0,
              "parameters": [
                "The method upgradeRibbon either upgrades an "
              ]
            },
            {
              "rmxp_raw": true,
              "code": 408,
              "indent": 0,
              "parameters": [
                "existing ribbon to the next one listed, or gives the "
              ]
            },
            {
              "rmxp_raw": true,
              "code": 408,
              "indent": 0,
              "parameters": [
                "first ribbon if the Pok\u00e9mon has none of them."
              ]
            },
            {
              "rmxp_raw": true,
              "code": 408,
              "indent": 0,
              "parameters": [
                "Returns nil if couldn't add/upgrade a ribbon."
              ]
            },
            {
              "rmxp_raw": true,
              "code": 101,
              "indent": 0,
              "parameters": [
                "\\rHi! I'm the Contest Lady!"
              ]
            },
            {
              "rmxp_raw": true,
              "code": 101,
              "indent": 0,
              "parameters": [
                "\\rI give out contest ribbons. Do you want one?"
              ]
            },
            {
              "rmxp_raw": true,
              "code": 102,
              "indent": 0,
              "parameters": [
                [
                  "Yes",
                  "No"
                ],
                2
              ]
            },
            {
              "rmxp_raw": true,
              "code": 402,
              "indent": 0,
              "parameters": [
                0,
                "Yes"
              ]
            },
            {
              "rmxp_raw": true,
              "code": 355,
              "indent": 1,
              "parameters": [
                "pkmn = $player.first_pokemon"
              ]
            },
            {
              "rmxp_raw": true,
              "code": 655,
              "indent": 1,
              "parameters": [
                "ret = pkmn.upgradeRibbon("
              ]
            },
            {
              "rmxp_raw": true,
              "code": 655,
              "indent": 1,
              "parameters": [
                "  :HOENNCOOL,"
              ]
            },
            {
              "rmxp_raw": true,
              "code": 655,
              "indent": 1,
              "parameters": [
                "  :HOENNCOOLSUPER,"
              ]
            },
            {
              "rmxp_raw": true,
              "code": 655,
              "indent": 1,
              "parameters": [
                "  :HOENNCOOLHYPER,"
              ]
            },
            {
              "rmxp_raw": true,
              "code": 655,
              "indent": 1,
              "parameters": [
                "  :HOENNCOOLMASTER"
              ]
            },
            {
              "rmxp_raw": true,
              "code": 655,
              "indent": 1,
              "parameters": [
                ")"
              ]
            },
            {
              "rmxp_raw": true,
              "code": 355,
              "indent": 1,
              "parameters": [
                "pbSet(1, ret || :NONE)"
              ]
            },
            {
              "rmxp_raw": true,
              "code": 655,
              "indent": 1,
              "parameters": [
                "pbSet(2, pkmn.name)"
              ]
            },
            {
              "rmxp_raw": true,
              "code": 655,
              "indent": 1,
              "parameters": [
                "if ret"
              ]
            },
            {
              "rmxp_raw": true,
              "code": 655,
              "indent": 1,
              "parameters": [
                "  data = GameData::Ribbon.get(ret)"
              ]
            },
            {
              "rmxp_raw": true,
              "code": 655,
              "indent": 1,
              "parameters": [
                "  pbSet(3, data.name)"
              ]
            },
            {
              "rmxp_raw": true,
              "code": 655,
              "indent": 1,
              "parameters": [
                "end"
              ]
            },
            {
              "rmxp_raw": true,
              "code": 111,
              "indent": 1,
              "parameters": [
                12,
                "pbGet(1) == :NONE"
              ]
            },
            {
              "rmxp_raw": true,
              "code": 101,
              "indent": 2,
              "parameters": [
                "\\rSorry, your \\v[2] already has the highest ranked "
              ]
            },
            {
              "rmxp_raw": true,
              "code": 401,
              "indent": 2,
              "parameters": [
                "Cool Ribbon."
              ]
            },
            {
              "rmxp_raw": true,
              "code": 0,
              "indent": 2,
              "parameters": []
            },
            {
              "rmxp_raw": true,
              "code": 411,
              "indent": 1,
              "parameters": []
            },
            {
              "rmxp_raw": true,
              "code": 101,
              "indent": 2,
              "parameters": [
                "\\PN received the \\v[3]."
              ]
            },
            {
              "rmxp_raw": true,
              "code": 401,
              "indent": 2,
              "parameters": [
                "\\me[Item get]\\wtnp[40]"
              ]
            },
            {
              "rmxp_raw": true,
              "code": 101,
              "indent": 2,
              "parameters": [
                "\\PN put the \\v[3] on \\v[2]."
              ]
            },
            {
              "rmxp_raw": true,
              "code": 0,
              "indent": 2,
              "parameters": []
            },
            {
              "rmxp_raw": true,
              "code": 412,
              "indent": 1,
              "parameters": []
            },
            {
              "rmxp_raw": true,
              "code": 0,
              "indent": 1,
              "parameters": []
            },
            {
              "rmxp_raw": true,
              "code": 402,
              "indent": 0,
              "parameters": [
                1,
                "No"
              ]
            },
            {
              "rmxp_raw": true,
              "code": 101,
              "indent": 1,
              "parameters": [
                "\\rThat's your choice."
              ]
            },
            {
              "rmxp_raw": true,
              "code": 0,
              "indent": 1,
              "parameters": []
            },
            {
              "rmxp_raw": true,
              "code": 404,
              "indent": 0,
