    "2,4": {
      "id": 4,
      "name": "Effort ribbon giver",
      "x": 2,
      "y": 4,
      "pages": [
        {
          "trigger": "Action Button",
          "condition_switch": null,
          "condition_switch_state": true,
          "condition_switch2": null,
          "condition_switch2_state": true,
          "condition_self_switch": null,
          "condition_variable_id": null,
          "condition_variable_value": 0,
          "condition_variable_operator": 1,
          "graphic_name": "NPC 04",
          "graphic": {
            "tile_id": 0,
            "character_name": "NPC 04",
            "character_hue": 0,
            "direction": 2,
            "pattern": 0,
            "opacity": 255,
            "blend_type": 0
          },
          "commands": [
            {
              "rmxp_raw": true,
              "code": 108,
              "indent": 0,
              "parameters": [
                "Looks at the total EVs of the lead Pok\u00e9mon, and "
              ]
            },
            {
              "rmxp_raw": true,
              "code": 408,
              "indent": 0,
              "parameters": [
                "rewards a ribbon to it if the total is maxed (equal to "
              ]
            },
            {
              "rmxp_raw": true,
              "code": 408,
              "indent": 0,
              "parameters": [
                "Pokemon::EV_LIMIT, which is 510 by default)."
              ]
            },
            {
              "rmxp_raw": true,
              "code": 355,
              "indent": 0,
              "parameters": [
                "pkmn = $player.first_pokemon"
              ]
            },
            {
              "rmxp_raw": true,
              "code": 655,
              "indent": 0,
              "parameters": [
                "total = 0"
              ]
            },
            {
              "rmxp_raw": true,
              "code": 655,
              "indent": 0,
              "parameters": [
                "pkmn.ev.each_value { |v| total += v }"
              ]
            },
            {
              "rmxp_raw": true,
              "code": 655,
              "indent": 0,
              "parameters": [
                "maxed = 0"
              ]
            },
            {
              "rmxp_raw": true,
              "code": 655,
              "indent": 0,
              "parameters": [
                "if total >= Pokemon::EV_LIMIT"
              ]
            },
            {
              "rmxp_raw": true,
              "code": 655,
              "indent": 0,
              "parameters": [
                "  maxed = 1"
              ]
            },
            {
              "rmxp_raw": true,
              "code": 655,
              "indent": 0,
              "parameters": [
                "end"
              ]
            },
            {
              "rmxp_raw": true,
              "code": 655,
              "indent": 0,
              "parameters": [
                "maxed = 2 if pkmn.hasRibbon?(:EFFORT)"
              ]
            },
            {
              "rmxp_raw": true,
              "code": 655,
              "indent": 0,
              "parameters": [
                "pbSet(1, pkmn.name)"
              ]
            },
            {
              "rmxp_raw": true,
              "code": 655,
              "indent": 0,
              "parameters": [
                "pbSet(2, maxed)"
              ]
            },
            {
              "rmxp_raw": true,
              "code": 101,
              "indent": 0,
              "parameters": [
                "\\rOh?\\nYour \\v[1]..."
              ]
            },
            {
              "rmxp_raw": true,
              "code": 111,
              "indent": 0,
              "parameters": [
                1,
                2,
                0,
                2,
                0
              ]
            },
            {
              "rmxp_raw": true,
              "code": 108,
              "indent": 1,
              "parameters": [
                "Pok\u00e9mon already has an Effort Ribbon."
              ]
            },
            {
              "rmxp_raw": true,
              "code": 101,
              "indent": 1,
              "parameters": [
                "\\rOh! Your \\v[1], that Effort Ribbon looks good on it!"
              ]
            },
            {
              "rmxp_raw": true,
              "code": 0,
              "indent": 1,
              "parameters": []
            },
            {
              "rmxp_raw": true,
              "code": 411,
              "indent": 0,
              "parameters": []
            },
            {
              "rmxp_raw": true,
              "code": 111,
              "indent": 1,
              "parameters": [
                1,
                2,
                0,
                1,
                0
              ]
            },
            {
              "rmxp_raw": true,
              "code": 108,
              "indent": 2,
              "parameters": [
                "Pok\u00e9mon has full EVs and does not already have an "
              ]
            },
            {
              "rmxp_raw": true,
              "code": 408,
              "indent": 2,
              "parameters": [
                "Effort Ribbon - give it that ribbon."
              ]
            },
            {
              "rmxp_raw": true,
              "code": 101,
              "indent": 2,
              "parameters": [
                "\\rWent for it stupendously!"
              ]
            },
            {
              "rmxp_raw": true,
              "code": 101,
              "indent": 2,
              "parameters": [
                "\\rAs its reward, please give it this Effort Ribbon."
              ]
            },
            {
              "rmxp_raw": true,
              "code": 355,
              "indent": 2,
              "parameters": [
                "pkmn = $player.first_pokemon"
              ]
            },
            {
              "rmxp_raw": true,
              "code": 655,
              "indent": 2,
              "parameters": [
                "pkmn.giveRibbon(:EFFORT)"
              ]
            },
            {
              "rmxp_raw": true,
              "code": 101,
              "indent": 2,
              "parameters": [
                "\\PN received the Effort Ribbon."
              ]
            },
            {
              "rmxp_raw": true,
              "code": 401,
              "indent": 2,
              "parameters": [
                "\\me[Item get]\\wtnp[20]"
              ]
            },
            {
              "rmxp_raw": true,
              "code": 101,
