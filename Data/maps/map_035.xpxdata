              "rmxp_raw": true,
              "code": 402,
              "indent": 1,
              "parameters": [
                1,
                "Deactivate"
              ]
            },
            {
              "rmxp_raw": true,
              "code": 101,
              "indent": 2,
              "parameters": [
                "\\bOkay. I'll fulfil my roadblock condition myself, by "
              ]
            },
            {
              "rmxp_raw": true,
              "code": 401,
              "indent": 2,
              "parameters": [
                "turning the Game Switch I depend on (5) to ON."
              ]
            },
            {
              "rmxp_raw": true,
              "code": 121,
              "indent": 2,
              "parameters": [
                5,
                5,
                0
              ]
            },
            {
              "rmxp_raw": true,
              "code": 108,
              "indent": 2,
              "parameters": [
                "When a \"Control Switches\" event command is used, "
              ]
            },
            {
              "rmxp_raw": true,
              "code": 408,
              "indent": 2,
              "parameters": [
                "all events on the map refresh themselves in case "
              ]
            },
            {
              "rmxp_raw": true,
              "code": 408,
              "indent": 2,
              "parameters": [
                "they should now use a different page. However, this "
              ]
            },
            {
              "rmxp_raw": true,
              "code": 408,
              "indent": 2,
              "parameters": [
                "also erases their forced move routes."
              ]
            },
            {
              "rmxp_raw": true,
              "code": 108,
              "indent": 2,
              "parameters": [
                "The refresh waits until the next frame to happen, but "
              ]
            },
            {
              "rmxp_raw": true,
              "code": 408,
              "indent": 2,
              "parameters": [
                "without the wait, the \"Set Move Route\" command "
              ]
            },
            {
              "rmxp_raw": true,
              "code": 408,
              "indent": 2,
              "parameters": [
                "below will have also run before then, and its move "
              ]
            },
            {
              "rmxp_raw": true,
              "code": 408,
              "indent": 2,
              "parameters": [
                "route would be erased. This is why we wait briefly "
              ]
            },
            {
              "rmxp_raw": true,
              "code": 408,
              "indent": 2,
              "parameters": [
                "now, to allow the refresh to happen before setting "
              ]
            },
            {
              "rmxp_raw": true,
              "code": 408,
              "indent": 2,
              "parameters": [
                "this event's move route."
              ]
            },
            {
              "rmxp_raw": true,
