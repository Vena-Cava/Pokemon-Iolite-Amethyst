            "blend_type": 0
          },
          "commands": [
            {
              "rmxp_raw": true,
              "code": 111,
              "indent": 0,
              "parameters": [
                6,
                0,
                6
              ]
            },
            {
              "rmxp_raw": true,
              "code": 355,
              "indent": 1,
              "parameters": [
                "pbNoticePlayer(get_self)"
              ]
            },
            {
              "rmxp_raw": true,
              "code": 101,
              "indent": 1,
              "parameters": [
                "\\bI stopped you as you walked past."
              ]
            },
            {
              "rmxp_raw": true,
              "code": 101,
              "indent": 1,
              "parameters": [
                "\\bHaving \"Sight(3)\" as my event's name, and the "
              ]
            },
            {
              "rmxp_raw": true,
              "code": 401,
              "indent": 1,
              "parameters": [
                "\"Event Touch\" trigger, tells me to activate whenever "
              ]
            },
            {
              "rmxp_raw": true,
              "code": 401,
              "indent": 1,
              "parameters": [
                "you enter any of the three tiles in front of me."
              ]
            },
            {
              "rmxp_raw": true,
              "code": 101,
              "indent": 1,
              "parameters": [
                "\\bpbExclaim makes me exclaim. pbNoticePlayer does "
              ]
            },
            {
              "rmxp_raw": true,
              "code": 401,
              "indent": 1,
              "parameters": [
                "the same thing, as well as make me approach you."
              ]
            },
            {
              "rmxp_raw": true,
              "code": 101,
              "indent": 1,
              "parameters": [
                "\\bTrainers use these features by default, but other "
              ]
            },
            {
              "rmxp_raw": true,
              "code": 401,
              "indent": 1,
              "parameters": [
                "NPCs like me can use them too. Roadblock events in "
              ]
            },
            {
              "rmxp_raw": true,
              "code": 401,
              "indent": 1,
              "parameters": [
                "particular love to use them."
              ]
            },
            {
              "rmxp_raw": true,
              "code": 101,
              "indent": 1,
              "parameters": [
                "\\bShall I turn you back like a real roadblock, or should "
              ]
            },
            {
              "rmxp_raw": true,
              "code": 401,
              "indent": 1,
              "parameters": [
                "I deactivate myself?"
              ]
            },
            {
              "rmxp_raw": true,
              "code": 102,
              "indent": 1,
              "parameters": [
                [
                  "Roadblock",
                  "Deactivate"
                ],
                0
              ]
            },
            {
              "rmxp_raw": true,
              "code": 402,
              "indent": 1,
              "parameters": [
                0,
                "Roadblock"
              ]
            },
            {
              "rmxp_raw": true,
              "code": 101,
              "indent": 2,
              "parameters": [
                "\\bCome back when Game Switch 5 is ON."
              ]
            },
            {
              "rmxp_raw": true,
              "code": 209,
              "indent": 2,
              "parameters": [
                -1,
                {
                  "repeat": false,
                  "skippable": false,
                  "list": [
                    {
                      "code": 16,
