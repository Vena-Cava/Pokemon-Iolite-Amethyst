          },
          "commands": [
            {
              "rmxp_raw": true,
              "code": 101,
              "indent": 0,
              "parameters": [
                "\\bHello, hello!\\nI am the official Name Rater!"
              ]
            },
            {
              "rmxp_raw": true,
              "code": 101,
              "indent": 0,
              "parameters": [
                "\\bWant me to rate the nicknames of your Pok\u00e9mon?"
              ]
            },
            {
              "rmxp_raw": true,
              "code": 102,
              "indent": 0,
              "parameters": [
                [
                  "Yes",
                  "No"
                ],
                2
              ]
            },
            {
              "rmxp_raw": true,
              "code": 402,
              "indent": 0,
              "parameters": [
                0,
                "Yes"
              ]
            },
            {
              "rmxp_raw": true,
              "code": 101,
              "indent": 1,
              "parameters": [
                "\\bWhich Pok\u00e9mon's nickname should I critique?"
              ]
            },
            {
              "rmxp_raw": true,
              "code": 108,
              "indent": 1,
              "parameters": [
                "Opens a screen for choosing a Pok\u00e9mon. The index "
              ]
            },
            {
              "rmxp_raw": true,
              "code": 408,
              "indent": 1,
              "parameters": [
                "is stored in Game Variable 1, and the name in Game "
              ]
            },
            {
              "rmxp_raw": true,
              "code": 408,
              "indent": 1,
              "parameters": [
                "Variable 3."
              ]
            },
            {
              "rmxp_raw": true,
              "code": 355,
              "indent": 1,
              "parameters": [
                "pbChoosePokemon(1, 3)"
              ]
            },
            {
              "rmxp_raw": true,
              "code": 108,
              "indent": 1,
              "parameters": [
                "If Game Variable 1 is less than 0, it means the player "
              ]
            },
            {
              "rmxp_raw": true,
              "code": 408,
              "indent": 1,
              "parameters": [
                "has canceled choosing a Pok\u00e9mon."
              ]
            },
            {
              "rmxp_raw": true,
              "code": 111,
              "indent": 1,
              "parameters": [
                1,
                1,
                0,
                0,
                4
              ]
            },
            {
              "rmxp_raw": true,
              "code": 101,
              "indent": 2,
              "parameters": [
                "\\bI see.\\nDo come visit again."
              ]
            },
            {
              "rmxp_raw": true,
              "code": 115,
              "indent": 2,
              "parameters": []
            },
            {
              "rmxp_raw": true,
              "code": 0,
              "indent": 2,
              "parameters": []
            },
            {
              "rmxp_raw": true,
              "code": 412,
              "indent": 1,
              "parameters": []
            },
            {
              "rmxp_raw": true,
              "code": 108,
              "indent": 1,
              "parameters": [
                "Check for eggs."
              ]
            },
            {
              "rmxp_raw": true,
              "code": 111,
              "indent": 1,
              "parameters": [
                12,
                "pbGetPokemon(1).egg?"
              ]
            },
            {
              "rmxp_raw": true,
              "code": 101,
              "indent": 2,
              "parameters": [
                "\\bNow, now... That is merely an Egg!"
              ]
            },
            {
              "rmxp_raw": true,
              "code": 115,
              "indent": 2,
              "parameters": []
            },
            {
              "rmxp_raw": true,
              "code": 0,
              "indent": 2,
              "parameters": []
            },
            {
              "rmxp_raw": true,
              "code": 412,
              "indent": 1,
              "parameters": []
            },
            {
              "rmxp_raw": true,
              "code": 108,
              "indent": 1,
              "parameters": [
                "Check for Shadow Pok\u00e9mon."
              ]
            },
            {
              "rmxp_raw": true,
              "code": 111,
              "indent": 1,
              "parameters": [
                12,
                "pbGetPokemon(1).shadowPokemon?"
              ]
            },
            {
              "rmxp_raw": true,
              "code": 101,
              "indent": 2,
              "parameters": [
                "\\bI wouldn't dare critique a Shadow Pok\u00e9mon's name!"
              ]
            },
            {
              "rmxp_raw": true,
              "code": 115,
              "indent": 2,
              "parameters": []
            },
            {
              "rmxp_raw": true,
              "code": 0,
              "indent": 2,
              "parameters": []
            },
            {
              "rmxp_raw": true,
              "code": 412,
              "indent": 1,
              "parameters": []
            },
            {
              "rmxp_raw": true,
              "code": 111,
              "indent": 1,
              "parameters": [
                12,
                "pbGetPokemon(1).foreign?($player)"
              ]
            },
            {
              "rmxp_raw": true,
              "code": 101,
              "indent": 2,
              "parameters": [
                "\\bHmmm... \\v[3] it is!"
              ]
            },
            {
              "rmxp_raw": true,
              "code": 101,
              "indent": 2,
              "parameters": [
                "\\bThis is a magnificent nickname! It is impeccably "
              ]
            },
            {
              "rmxp_raw": true,
              "code": 401,
              "indent": 2,
              "parameters": [
                "beyond reproach!"
              ]
            },
            {
              "rmxp_raw": true,
              "code": 101,
              "indent": 2,
              "parameters": [
                "\\bYou'll do well to cherish your \\v[3] now and "
              ]
            },
            {
              "rmxp_raw": true,
              "code": 401,
              "indent": 2,
              "parameters": [
                "beyond."
              ]
            },
            {
              "rmxp_raw": true,
              "code": 115,
              "indent": 2,
              "parameters": []
            },
            {
              "rmxp_raw": true,
              "code": 0,
              "indent": 2,
              "parameters": []
            },
            {
              "rmxp_raw": true,
              "code": 412,
              "indent": 1,
              "parameters": []
            },
            {
              "rmxp_raw": true,
              "code": 101,
              "indent": 1,
              "parameters": [
                "\\b\\v[3], is it?\\nThat is a decent nickname!"
              ]
            },
            {
              "rmxp_raw": true,
              "code": 101,
              "indent": 1,
              "parameters": [
                "\\bBut, would you like me to give it a nicer name?"
              ]
            },
            {
              "rmxp_raw": true,
              "code": 101,
              "indent": 1,
              "parameters": [
                "\\bHow about it?"
              ]
            },
            {
              "rmxp_raw": true,
              "code": 102,
              "indent": 1,
              "parameters": [
                [
                  "Yes",
                  "No"
                ],
                2
              ]
            },
            {
              "rmxp_raw": true,
              "code": 402,
              "indent": 1,
              "parameters": [
                0,
                "Yes"
              ]
            },
            {
              "rmxp_raw": true,
              "code": 101,
              "indent": 2,
              "parameters": [
                "\\bAh, good. Then, what shall the new nickname be?"
              ]
            },
            {
              "rmxp_raw": true,
              "code": 355,
              "indent": 2,
              "parameters": [
                "pkmn = pbGetPokemon(1)"
              ]
            },
            {
              "rmxp_raw": true,
              "code": 655,
              "indent": 2,
              "parameters": [
                "species = pkmn.speciesName"
              ]
            },
            {
              "rmxp_raw": true,
              "code": 655,
              "indent": 2,
              "parameters": [
                "pbSet(4, species)"
              ]
            },
            {
              "rmxp_raw": true,
              "code": 655,
              "indent": 2,
              "parameters": [
                "pbTextEntry("
              ]
            },
            {
              "rmxp_raw": true,
              "code": 655,
              "indent": 2,
              "parameters": [
                "  _I(\"{1}'s nickname?\", species),"
              ]
            },
            {
              "rmxp_raw": true,
              "code": 655,
              "indent": 2,
              "parameters": [
                "  0, Pokemon::MAX_NAME_SIZE, 5"
              ]
            },
            {
              "rmxp_raw": true,
              "code": 655,
              "indent": 2,
              "parameters": [
                ")"
              ]
            },
            {
              "rmxp_raw": true,
              "code": 111,
              "indent": 2,
              "parameters": [
                12,
                "pbGet(5) == pbGet(3) || (pbGet(5) == \"\" && pbGet(3) == pbGet(4))"
              ]
            },
            {
              "rmxp_raw": true,
              "code": 108,
              "indent": 3,
              "parameters": [
                "The Pok\u00e9mon's nickname wasn't changed."
              ]
            },
            {
              "rmxp_raw": true,
              "code": 101,
              "indent": 3,
              "parameters": [
                "\\bI see. You're right, there's no need to change this "
              ]
            },
            {
              "rmxp_raw": true,
              "code": 401,
              "indent": 3,
              "parameters": [
                "Pok\u00e9mon's nickname."
              ]
            },
            {
              "rmxp_raw": true,
              "code": 101,
              "indent": 3,
              "parameters": [
                "\\bIt already had a superb name!"
              ]
            },
            {
              "rmxp_raw": true,
              "code": 0,
              "indent": 3,
              "parameters": []
            },
            {
              "rmxp_raw": true,
              "code": 411,
              "indent": 2,
              "parameters": []
            },
            {
              "rmxp_raw": true,
              "code": 111,
              "indent": 3,
              "parameters": [
                12,
                "pbGet(5) == \"\" || pbGet(5) == pbGet(4)"
              ]
            },
            {
              "rmxp_raw": true,
              "code": 108,
              "indent": 4,
              "parameters": [
                "Resets the Pok\u00e9mon's nickname to the species name."
              ]
            },
            {
              "rmxp_raw": true,
              "code": 355,
              "indent": 4,
              "parameters": [
                "pkmn = pbGetPokemon(1)"
              ]
            },
            {
              "rmxp_raw": true,
              "code": 655,
              "indent": 4,
              "parameters": [
                "pkmn.name = nil"
              ]
            },
            {
              "rmxp_raw": true,
              "code": 655,
              "indent": 4,
              "parameters": [
                "pbSet(3, pkmn.name)"
              ]
            },
            {
              "rmxp_raw": true,
              "code": 101,
              "indent": 4,
              "parameters": [
                "\\bDone! From now on, this Pok\u00e9mon shall be known"
              ]
            },
            {
              "rmxp_raw": true,
              "code": 401,
              "indent": 4,
              "parameters": [
                "as \\v[3]!"
              ]
            },
            {
              "rmxp_raw": true,
              "code": 101,
              "indent": 4,
              "parameters": [
                "\\bIt looks no different from before, and yet, this is "
              ]
            },
            {
              "rmxp_raw": true,
              "code": 401,
              "indent": 4,
              "parameters": [
                "vastly superior!"
              ]
            },
            {
              "rmxp_raw": true,
              "code": 101,
              "indent": 4,
              "parameters": [
                "\\bHow fortunate for you!"
              ]
            },
            {
              "rmxp_raw": true,
              "code": 0,
              "indent": 4,
              "parameters": []
            },
            {
              "rmxp_raw": true,
              "code": 411,
              "indent": 3,
              "parameters": []
            },
            {
              "rmxp_raw": true,
              "code": 108,
              "indent": 4,
              "parameters": [
                "Retrieves the Pok\u00e9mon whose party index is stored in "
              ]
            },
            {
              "rmxp_raw": true,
              "code": 408,
              "indent": 4,
              "parameters": [
                "Game Variable 1, and changes its name to the name "
              ]
            },
            {
              "rmxp_raw": true,
              "code": 408,
              "indent": 4,
              "parameters": [
                "stored in Game Variable 5."
              ]
            },
            {
              "rmxp_raw": true,
              "code": 355,
              "indent": 4,
              "parameters": [
                "pkmn = pbGetPokemon(1)"
              ]
            },
            {
              "rmxp_raw": true,
              "code": 655,
              "indent": 4,
              "parameters": [
                "pkmn.name = pbGet(5)"
              ]
            },
            {
              "rmxp_raw": true,
              "code": 101,
              "indent": 4,
              "parameters": [
                "\\bDone! From now on, this Pok\u00e9mon shall be known"
              ]
            },
            {
              "rmxp_raw": true,
              "code": 401,
              "indent": 4,
              "parameters": [
